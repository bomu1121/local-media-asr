{
  "productName": "音视频转写助手",
  "version": "0.1.0",
  "identifier": "com.media.transcriber",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm vite build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "音视频转写助手",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "languages": ["SimpChinese", "English"],
        "installMode": "currentUser"
      }
    },
    "externalBin": [
      "binaries/asr_worker"
    ],
    "resources": {
      "models": "models"
    }
  },
  "plugins": {}
}