{
  "productName": "local-media-asr",
  "version": "0.1.0",
  "identifier": "com.localmedia.asr",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "\u93c8\ue100\u6e74\u6fef\u638d\u7d8bASR - \u7ec2\u8364\u568e\u95ca\u5ba0\ue74b\u68f0\u6223\u6d46\u93c2\u56e7\u74e7",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "languages": [
          "SimpChinese",
          "English"
        ],
        "installMode": "currentUser"
      }
    },
    "resources": [
      "sherpa-onnx-lib\\sherpa-onnx-v1.12.9-win-x64-shared\\lib\\sherpa-onnx-c-api.dll",
      "sherpa-onnx-lib\\sherpa-onnx-v1.12.9-win-x64-shared\\lib\\sherpa-onnx-cxx-api.dll",
      "sherpa-onnx-lib\\sherpa-onnx-v1.12.9-win-x64-shared\\lib\\onnxruntime.dll",
      "sherpa-onnx-lib\\sherpa-onnx-v1.12.9-win-x64-shared\\lib\\onnxruntime_providers_shared.dll"
    ]
  },
  "plugins": {}
}