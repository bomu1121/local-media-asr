{
  "$schema": "https://raw.githubusercontent.com/nicfv/tauri-plugin-settings/v2/schemas/tauri-conf.schema.json",
  "productName": "local-media-asr",
  "version": "0.1.0",
  "identifier": "com.localmedia.asr",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "本地媒体ASR - 离线音视频转文字",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "dragDropEnabled": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/ffmpeg"
    ],
    "resources": {
      "models/mandatory/*": "./",
      "models/optional/*": "./"
    },
    "windows": {
      "nsis": {
        "languages": ["SimpChinese", "English"],
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {
    "dialog": {},
    "fs": {
      "scope": {
        "allow": ["**"],
        "deny": []
      }
    },
    "shell": {
      "scope": [
        {
          "name": "ffmpeg-sidecar",
          "cmd": "binaries/ffmpeg",
          "args": true
        }
      ]
    }
  }
}
